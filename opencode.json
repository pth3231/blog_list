{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "shadcn": {
      "type": "local",
      "command": [
        "npx",
        "shadcn@latest",
        "mcp"
      ],
      "enabled": true
    },
    "OpenWebSearch": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "open-websearch@latest"
      ],
      "enabled": true
    }
  }
}