# Copy to .env.prod and fill in real values. .env.prod is gitignored — NEVER commit it.
# The app container reads these at runtime (see compose.prod.yaml).

# MongoDB. Default points at the local compose `mongo` service.
# For MongoDB Atlas: set your atlas URI here, then delete the `mongo` service
# (and the app's `depends_on`) in compose.prod.yaml.
MONGODB_URI=mongodb://mongo:27017/blog_list

# Auth — generate a long random secret (>= 16 chars):  openssl rand -hex 32
JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRES_IN=7d
COOKIE_NAME=blog_session
BCRYPT_ROUNDS=12

# Cloudflare Tunnel token — serves the site over HTTPS with no inbound port.
# Create a tunnel in Cloudflare Zero Trust and paste its install token here.
# Guide: docs/cloudflare-tunnel.md
TUNNEL_TOKEN=